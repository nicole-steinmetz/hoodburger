{%- comment -%} Drinks section — hardcoded, do not auto-generate {%- endcomment -%}

<h2 class="menu__heading">Cold Drinks</h2>

<div class="drinks-featured">
  <div class="drinks-card">
    <div class="drinks-card__media">
      <img src="{{ 'hb-menu-coke.jpg' | asset_url }}" alt="Coke" loading="lazy" width="302" height="302">
    </div>
    <h3 class="drinks-card__title">Coke</h3>
    <ul class="drinks-card__variants">
      <li>Can</li>
      <li>Cherry</li>
      <li>No Sugar</li>
      <li>Vanilla</li>
    </ul>
  </div>
  <div class="drinks-card">
    <div class="drinks-card__media">
      <img src="{{ 'hb-menu-dr-pepper.jpg' | asset_url }}" alt="Dr Pepper" loading="lazy" width="302" height="302">
    </div>
    <h3 class="drinks-card__title">Dr Pepper</h3>
    <ul class="drinks-card__variants">
      <li>Cherry</li>
      <li>Cream Soda</li>
    </ul>
  </div>
  <div class="drinks-card">
    <div class="drinks-card__media">
      <img src="{{ 'hb-menu-fanta.jpg' | asset_url }}" alt="Fanta" loading="lazy" width="302" height="302">
    </div>
    <h3 class="drinks-card__title">Fanta</h3>
    <ul class="drinks-card__variants">
      <li>Grape Can</li>
      <li>Peach Can</li>
      <li>Pineapple Can</li>
      <li>Strawberry Can</li>
      <li>Berry Can</li>
    </ul>
  </div>
  <div class="drinks-card">
    <div class="drinks-card__media">
      <img src="{{ 'hb-menu-jarritos.jpg' | asset_url }}" alt="Jarritos" loading="lazy" width="302" height="302">
    </div>
    <h3 class="drinks-card__title">Jarritos</h3>
    <ul class="drinks-card__variants">
      <li>Guava</li>
      <li>Lime</li>
      <li>Mandarin</li>
      <li>Mexican Cola</li>
    </ul>
  </div>
</div>

<div class="drinks-brands">
  <div class="drinks-brand">
    <div class="drinks-brand__media">
      <img src="{{ 'hb-menu-arizona-grapeade.jpg' | asset_url }}" alt="Arizona Grapeade" loading="lazy" width="302" height="302">
    </div>
    <h3 class="drinks-brand__title">Other</h3>
    <ul class="drinks-brand__items">
      <li>Cream Soda</li>
      <li>Root Beer</li>
      <li>Sparkling Water</li>
      <li>Still Water</li>
    </ul>
