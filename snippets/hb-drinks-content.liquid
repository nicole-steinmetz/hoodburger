  <div class="drinks-brand">
    <div class="drinks-brand__media">
      <img src="{{ 'hb-menu-passiona.jpg' | asset_url }}" alt="Passiona" loading="lazy" width="302" height="302">
    </div>
    <h3 class="drinks-brand__title">Schweppes</h3>
    <ul class="drinks-brand__items">
      <li>7up</li>
      <li>Mountain Dew</li>
      <li>Passiona</li>
      <li>Pepsi Max</li>
      <li>Solo</li>
      <li>Sunkist</li>
      <li>Pepsi</li>
      <li>Sunkist Zero Sugar</li>
      <li>Solo Zero Sugar</li>
    </ul>
  </div>
</div>
