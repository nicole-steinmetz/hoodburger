{%- comment -%}
  sections/hb-catering.liquid — Catering page.
  Styled by assets/hb-catering.css

  Layout (top → bottom):
    1. Page heading — "Catering" (H1, Helvetica Bold, 52px desktop / 50px mobile)
    2. JotForm enquiry form (iframe embed) — sits directly under the heading
    3. Hero photo — below the form

  Why an iframe + hb-catering.js (and NOT the pasted <script> snippet):
    - Shopify strips <script> tags from `html` / richtext section settings, so the
      JotForm jsform/embed snippet cannot live in a setting field.
    - The iframe is hard-coded here (server-side, indexable wrapper) and the JotForm
      "embed handler" (which auto-resizes the iframe to the form's height) is loaded
      by hb-catering.js, which listens for shopify:section:load per theme rules.

  Theme dev rules:
    - HTML/Liquid first. The iframe is server-side.
    - The JotForm embed-handler script is a necessary third-party exception
      (it IS the form, not a pop-up). Loaded + deferred via hb-catering.js.
    - All custom JS listens for shopify:section:load.
{%- endcomment -%}

{{ 'hb-catering.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign form_id = section.settings.jotform_id | default: '261770601059051'
  assign form_height = section.settings.form_height | default: 539
-%}

<div class="catering" id="hb-catering-{{ section.id }}">

  {%- comment -%} ─────────────────── 1. HEADING ─────────────────── {%- endcomment -%}
  <div class="container catering__header">
    <h1 class="catering__heading">{{ section.settings.heading | default: 'Catering' }}</h1>
  </div>

  {%- comment -%} ─────────────────── 2. JOTFORM EMBED ─────────────────── {%- endcomment -%}
  <div class="container catering__embed">
    <iframe
      id="JotFormIFrame-{{ form_id }}"
      class="catering__form"
      title="{{ section.settings.form_title | default: 'Catering Enquiry' | escape }}"
      src="https://form.jotform.com/{{ form_id }}"
      allow="geolocation; microphone; camera; fullscreen; payment"
      allowtransparency="true"
      frameborder="0"
      scrolling="no"
      style="min-width:100%;max-width:100%;height:{{ form_height }}px;border:none;"
      data-jotform-id="{{ form_id }}"
    ></iframe>
  </div>

  {%- comment -%} ─────────────────── 3. HERO PHOTO ─────────────────── {%- endcomment -%}
  {%- if section.settings.hero_image != blank
      or section.settings.hero_image_mobile != blank
      or section.settings.hero_asset != blank -%}
    {%- liquid
      assign hero_desktop = section.settings.hero_asset
      assign hero_mobile = section.settings.hero_asset_mobile | default: hero_desktop
    -%}
    <div class="catering__hero">
      <picture class="catering__hero-picture">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 2880
            | image_tag:
              class: 'catering__hero-img',
              loading: 'lazy',
              widths: '750, 1100, 1500, 2000, 2880',
              sizes: '100vw',
              alt: section.settings.hero_alt
          }}
        {%- elsif section.settings.hero_image_mobile != blank -%}
          <source media="(min-width: 990px)" srcset="{{ hero_desktop | asset_url }}">
          {{
            section.settings.hero_image_mobile
            | image_url: width: 750
            | image_tag:
              class: 'catering__hero-img',
              loading: 'lazy',
              widths: '345, 690',
              sizes: '100vw',
              alt: section.settings.hero_alt
          }}
        {%- else -%}
          <source media="(min-width: 990px)" srcset="{{ hero_desktop | asset_url }}">
          <img
            class="catering__hero-img"
            src="{{ hero_mobile | asset_url }}"
            alt="{{ section.settings.hero_alt | escape }}"
            width="345"
            height="528"
            loading="lazy"
          >
        {%- endif -%}
      </picture>
    </div>
  {%- endif -%}

</div>

<script src="{{ 'hb-catering.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "HB Catering",
  "tag": "section",
  "class": "hb-catering-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Catering"
    },
    {
      "type": "header",
      "content": "JotForm enquiry form"
    },
    {
      "type": "text",
      "id": "jotform_id",
      "label": "JotForm form ID",
      "info": "The numeric ID from the form URL, e.g. 261770601059051",
      "default": "261770601059051"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title (accessibility)",
      "default": "Catering Enquiry"
    },
    {
      "type": "number",
      "id": "form_height",
      "label": "Initial form height (px)",
      "info": "Starting height before JotForm auto-resizes. Prevents layout jump.",
      "default": 539
    },
    {
      "type": "header",
      "content": "Hero image (optional — appears below the form)"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image — desktop (overrides asset below)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image — mobile (overrides mobile asset below)"
    },
    {
      "type": "text",
      "id": "hero_asset",
      "label": "Desktop hero asset filename",
      "info": "Theme asset in /assets (e.g. hb-catering-hero.png). Leave blank to hide the image entirely."
    },
    {
      "type": "text",
      "id": "hero_asset_mobile",
      "label": "Mobile hero asset filename",
      "info": "Theme asset in /assets. Falls back to the desktop asset if blank."
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Hero image alt text",
      "default": "Hoodburger catering spread"
    }
  ],
  "presets": [
    {
      "name": "HB Catering"
    }
  ]
}
{% endschema %}
