{%- comment -%}
  sections/hb-rewards-hero.liquid
  Red illustration hero for the Rewards page.
  Loads hb-rewards.css (once per page — do NOT duplicate in other rewards sections).
  Figma ref: node 17:10718 (red band) + node 17:10722 (HoodburgerDesigns1 illustration).
{%- endcomment -%}

{{ 'hb-rewards.css' | asset_url | stylesheet_tag }}

<section class="rewards-hero">
  <div class="rewards-hero__frame">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2880
        | image_tag:
          class: 'rewards-hero__media',
          loading: 'eager',
          fetchpriority: 'high',
          alt: '',
          widths: '750, 1100, 1500, 2000, 2880',
          sizes: '100vw'
      }}
    {%- elsif section.settings.fallback_asset != blank -%}
      <img
        class="rewards-hero__media"
        src="{{ section.settings.fallback_asset | asset_url }}"
        alt=""
        width="1440"
        height="887"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}

    {%- if section.settings.mobile_cta_label != blank -%}
      <div class="rewards-hero__mobile-cta">
        <a class="btn btn--order" href="{{ section.settings.mobile_cta_link | default: '#' }}">
          {{ section.settings.mobile_cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "HB Rewards Hero",
  "tag": "section",
  "class": "hb-rewards-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero illustration",
      "info": "Upload the castle/characters artwork. Overrides fallback asset below."
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "Fallback asset filename",
      "info": "Theme asset filename in /assets, e.g. hb-rewards-hero.jpg. Used until image_picker is set.",
      "default": "hb-rewards-hero.jpg"
    },
    {
      "type": "text",
      "id": "mobile_cta_label",
      "label": "Mobile CTA label",
      "default": "ORDER NOW"
    },
    {
      "type": "url",
      "id": "mobile_cta_link",
      "label": "Mobile CTA link"
    }
  ],
  "presets": [
    {
      "name": "HB Rewards Hero"
    }
  ]
}
{% endschema %}
