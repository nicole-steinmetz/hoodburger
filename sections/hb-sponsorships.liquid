{%- comment -%}
  sections/hb-sponsorships.liquid — Sponsorships page.
  Styled by assets/hb-sponsorships.css

  Layout (top → bottom):
    1. Page heading — "Sponsorships" (H1, Helvetica Bold, 52px desktop / 50px mobile)
    2. JotForm application form (iframe embed) — sits directly under the heading
    3. Hero photo — optional, below the form (blank by default; comp has none)

  NOTE: the full-width photo at the very top of the comp and the yellow
  "become a Wizard" band are NOT in this section. They are the global
  hb-page-hero and hb-cta-bar sections, composed in templates/page.sponsorships.json.

  Why an iframe + hb-sponsorships.js (and NOT the pasted <script> snippet):
    - Shopify strips <script> tags from `html` / richtext section settings, so the
      JotForm jsform/embed snippet cannot live in a setting field.
    - The iframe is hard-coded here (server-side, indexable wrapper) and the JotForm
      "embed handler" (which auto-resizes the iframe to the form's height) is loaded
      by hb-sponsorships.js, which listens for shopify:section:load per theme rules.

  Theme dev rules:
    - HTML/Liquid first. The iframe is server-side.
    - All custom JS listens for shopify:section:load.
    - No Dawn core files touched. Tokens come from hb-home.css :root.
{%- endcomment -%}

{{ 'hb-sponsorships.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign form_id = section.settings.jotform_id
  assign form_height = section.settings.form_height | default: 539
-%}

<div class="sponsorships" id="hb-sponsorships-{{ section.id }}">

  {%- comment -%} ─────────────────── 1. HEADING ─────────────────── {%- endcomment -%}
  <div class="container sponsorships__header">
    <h1 class="sponsorships__heading">{{ section.settings.heading | default: 'Sponsorships' }}</h1>
  </div>

  {%- comment -%} ─────────────────── 2. JOTFORM EMBED ─────────────────── {%- endcomment -%}
  <div class="container sponsorships__embed">
    {%- if form_id != blank -%}
      <iframe
        id="JotFormIFrame-{{ form_id }}"
        class="sponsorships__form"
        title="{{ section.settings.form_title | default: 'Sponsorship Application' | escape }}"
        src="https://form.jotform.com/{{ form_id }}"
        allow="geolocation; microphone; camera; fullscreen; payment"
        allowtransparency="true"
        frameborder="0"
        scrolling="no"
        style="min-width:100%;max-width:100%;height:{{ form_height }}px;border:none;"
        data-jotform-id="{{ form_id }}"
      ></iframe>
    {%- else -%}
      {%- comment -%}
        No form ID set yet. Render an editor-only placeholder so the page never
        accidentally embeds another form, and so the gap is obvious in Customise.
      {%- endcomment -%}
      {%- if request.design_mode -%}
        <p class="sponsorships__form-placeholder">
          Add the Sponsorship JotForm ID in this section’s settings to embed the form.
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%} ─────────────────── 3. HERO PHOTO (optional) ─────────────────── {%- endcomment -%}
  {%- if section.settings.hero_image != blank
      or section.settings.hero_image_mobile != blank
      or section.settings.hero_asset != blank -%}
    {%- liquid
      assign hero_desktop = section.settings.hero_asset
      assign hero_mobile = section.settings.hero_asset_mobile | default: hero_desktop
    -%}
    <div class="sponsorships__hero">
      <picture class="sponsorships__hero-picture">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 2880
            | image_tag:
              class: 'sponsorships__hero-img',
              loading: 'lazy',
              widths: '750, 1100, 1500, 2000, 2880',
              sizes: '100vw',
              alt: section.settings.hero_alt
          }}
        {%- elsif section.settings.hero_image_mobile != blank -%}
          <source media="(min-width: 990px)" srcset="{{ hero_desktop | asset_url }}">
          {{
            section.settings.hero_image_mobile
            | image_url: width: 750
            | image_tag:
              class: 'sponsorships__hero-img',
              loading: 'lazy',
              widths: '345, 690',
              sizes: '100vw',
              alt: section.settings.hero_alt
          }}
        {%- else -%}
          <source media="(min-width: 990px)" srcset="{{ hero_desktop | asset_url }}">
          <img
            class="sponsorships__hero-img"
            src="{{ hero_mobile | asset_url }}"
            alt="{{ section.settings.hero_alt | escape }}"
            width="345"
            height="528"
            loading="lazy"
          >
        {%- endif -%}
      </picture>
    </div>
  {%- endif -%}

</div>

<script src="{{ 'hb-sponsorships.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "HB Sponsorships",
  "tag": "section",
  "class": "hb-sponsorships-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Sponsorships"
    },
    {
      "type": "header",
      "content": "JotForm application form"
    },
    {
      "type": "text",
      "id": "jotform_id",
      "label": "JotForm form ID",
      "info": "The numeric ID from the form URL, e.g. 261770601059051. Leave blank until the Sponsorships form exists — DO NOT reuse the Catering form ID."
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title (accessibility)",
      "default": "Sponsorship Application"
    },
    {
      "type": "number",
      "id": "form_height",
      "label": "Initial form height (px)",
      "info": "Starting height before JotForm auto-resizes. Prevents layout jump.",
      "default": 539
    },
    {
      "type": "header",
      "content": "Hero image (optional — appears below the form)"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image — desktop (overrides asset below)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image — mobile (overrides mobile asset below)"
    },
    {
      "type": "text",
      "id": "hero_asset",
      "label": "Desktop hero asset filename",
      "info": "Theme asset in /assets. Leave blank to hide the image entirely (comp has none)."
    },
    {
      "type": "text",
      "id": "hero_asset_mobile",
      "label": "Mobile hero asset filename",
      "info": "Theme asset in /assets. Falls back to the desktop asset if blank."
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Hero image alt text",
      "default": "Hoodburger sponsorships"
    }
  ],
  "presets": [
    {
      "name": "HB Sponsorships"
    }
  ]
}
{% endschema %}
