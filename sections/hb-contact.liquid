{%- comment -%}
  sections/hb-contact.liquid — Contact page (H1 + Customer Complaints JotForm).
  Form ID 261770784260057 is locked — do not change without updating JotForm embed.
  Resize handler: assets/hb-contact.js (replaces pasted <script> tags Shopify strips).
  Keep Online Store → Pages → Contact body empty (no duplicate iframe paste).
{%- endcomment -%}

{%- liquid
  assign form_id = '261770784260057'
  assign form_height = section.settings.form_height | default: 540
-%}

<section class="contact-page" id="hb-contact-{{ section.id }}">
  <div class="container contact-page__inner">
    <div class="contact-page__header">
      <h1 class="contact-page__heading">{{ section.settings.heading | default: page.title | default: 'Contact' }}</h1>
    </div>

    <div class="contact-page__embed">
      <iframe
        id="JotFormIFrame-{{ form_id }}"
        class="contact-page__iframe"
        title="Customer Complaints"
        src="https://form.jotform.com/{{ form_id }}"
        allow="geolocation; microphone; camera; fullscreen; payment"
        allowtransparency="true"
        frameborder="0"
        scrolling="no"
        style="min-width:100%;max-width:100%;height:{{ form_height }}px;border:none;"
        data-jotform-id="{{ form_id }}"
        onload="window.parent.scrollTo(0,0)"
      ></iframe>
    </div>
  </div>
</section>

<script src="{{ 'hb-contact.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "HB Contact",
  "tag": "section",
  "class": "hb-contact-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Contact"
    },
    {
      "type": "paragraph",
      "content": "Customer Complaints form (JotForm 261770784260057) is built into this section."
    },
    {
      "type": "range",
      "id": "form_height",
      "min": 400,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "label": "Initial iframe height",
      "default": 540
    }
  ],
  "presets": [
    {
      "name": "HB Contact"
    }
  ]
}
{% endschema %}
