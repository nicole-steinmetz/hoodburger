{%- comment -%} sections/hb-cta-bar.liquid — yellow CTA band. Styled by hb-home.css {%- endcomment -%}
<section class="cta-bar cta-bar--order{% if section.settings.mobile_only %} cta-bar--mobile-only{% endif %}">
  <div class="cta-bar__inner">
    <div class="container cta-bar__content">
    {%- if section.settings.headline != blank -%}
      <p class="cta-bar__text">{{ section.settings.headline }}</p>
    {%- endif -%}

    {%- if section.settings.order_label != blank -%}
      <a class="btn btn--order-mobile cta-bar__order" href="{{ section.settings.order_link | default: '#' }}">
        {{ section.settings.order_label }}
      </a>
    {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HB CTA Bar",
  "tag": "section",
  "class": "hb-cta-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "mobile_only",
      "label": "Show on mobile only",
      "default": false
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Eat hamburgers, become a Wizard, get rewards."
    },
    {
      "type": "text",
      "id": "order_label",
      "label": "Order button label",
      "default": "Order Now"
    },
    {
      "type": "url",
      "id": "order_link",
      "label": "Order button link"
    }
  ],
  "presets": [
    {
      "name": "HB CTA Bar"
    }
  ]
}
{% endschema %}
