{%- comment -%}
  sections/hb-storepoint-page.liquid — Shared layout for Store Locations + Order Now.
  Layout: H1 → Storepoint widget → inset hero image (optional earn-points badge).
  Styled by hb-home.css (.locations). JS: hb-storepoint.js
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  if heading == blank
    assign heading = page.title
  endif

  assign hero_desktop = section.settings.hero_asset
  if hero_desktop == blank
    assign hero_desktop = 'hb-locations-hero.jpg'
  endif

  assign hero_mobile = section.settings.hero_asset_mobile
  if hero_mobile == blank
    assign hero_mobile = hero_desktop
  endif
-%}

<section class="locations" id="hb-storepoint-page-{{ section.id }}">
  <div class="container locations__inner">
    <h1 class="locations__heading">{{ heading | escape }}</h1>

    <div class="locations__content">
      <div
        class="locations__widget"
        id="storepoint-widget-{{ section.id }}"
        data-storepoint-widget
        data-storepoint-map-id="{{ section.settings.storepoint_map_id | default: '16a29894aabfbe' }}"
        aria-label="Store locator"
      ></div>

      <div class="locations__media-wrap">
        <picture class="locations__picture">
          {%- if section.settings.hero_image != blank -%}
            {{
              section.settings.hero_image
              | image_url: width: 2880
              | image_tag:
                class: 'locations__media',
                loading: 'lazy',
                alt: heading,
                widths: '750, 1100, 1500, 2000, 2880',
                sizes: '(min-width: 1024px) 1280px, 100vw'
            }}
          {%- elsif section.settings.hero_image_mobile != blank -%}
            <source
              media="(min-width: 1024px)"
              srcset="{{ hero_desktop | asset_url }}"
            >
            {{
              section.settings.hero_image_mobile
              | image_url: width: 750
              | image_tag:
                class: 'locations__media',
                loading: 'lazy',
                alt: heading,
                widths: '345, 690',
                sizes: '100vw'
            }}
          {%- else -%}
            <source
              media="(min-width: 1024px)"
              srcset="{{ hero_desktop | asset_url }}"
            >
            <img
              class="locations__media"
              src="{{ hero_mobile | asset_url }}"
              alt="{{ heading | escape }}"
              width="345"
              height="528"
              loading="lazy"
            >
          {%- endif -%}
        </picture>

        {%- if section.settings.earn_points_badge != blank -%}
          <img
            class="locations__badge"
            src="{{ section.settings.earn_points_badge | asset_url }}"
            alt="{{ section.settings.earn_points_badge_alt | default: 'Earn loyalty points on pickup orders' }}"
            width="186"
            height="70"
            loading="lazy"
          >
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'hb-storepoint.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "HB Storepoint Page",
  "tag": "section",
  "class": "hb-storepoint-page-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading"
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image — desktop (overrides asset below)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image — mobile (overrides mobile asset below)"
    },
    {
      "type": "text",
      "id": "hero_asset",
      "label": "Desktop hero asset filename",
      "info": "Theme asset in /assets",
      "default": "hb-locations-hero.jpg"
    },
    {
      "type": "text",
      "id": "hero_asset_mobile",
      "label": "Mobile hero asset filename",
      "info": "Falls back to desktop asset if blank"
    },
    {
      "type": "text",
      "id": "earn_points_badge",
      "label": "Earn-points badge asset filename (optional)",
      "info": "Leave blank to hide the badge"
    },
    {
      "type": "text",
      "id": "earn_points_badge_alt",
      "label": "Earn-points badge alt text",
      "default": "Earn loyalty points on pickup orders"
    },
    {
      "type": "header",
      "content": "Storepoint embed"
    },
    {
      "type": "text",
      "id": "storepoint_map_id",
      "label": "Storepoint map ID",
      "default": "16a29894aabfbe"
    }
  ],
  "presets": [
    {
      "name": "HB Storepoint Page"
    }
  ]
}
{% endschema %}
