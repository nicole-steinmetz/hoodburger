{%- comment -%}
  sections/hb-story-about.liquid — Our Story / About card.
  Styled by assets/hb-story.css

  Figma refs:
    Desktop  → cRjbVkrcT1wMuRheABgpPZ node 17:13043 (FAQ container 17:13085)
    Mobile   → cRjbVkrcT1wMuRheABgpPZ node 17:13297 (FAQ container 17:13384)

  Layout:
    - Hairline-bordered card.
    - Desktop: image left (1/3) / About heading + body + socials right (2/3).
    - Mobile : image on top, text + socials below.
    - Social icons + URLs match hb-footer.liquid (Instagram, TikTok).

  Theme dev rules:
    - HTML/Liquid first. All content server-side, indexable without JS. No JS here.
{%- endcomment -%}

{{ 'hb-story.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign about_asset = section.settings.image_asset | default: 'hb-story-about.jpg'
  assign about_alt   = section.settings.image_alt | default: 'Hoodburger team at work'

  comment
    Social URLs match hb-footer / footer-group.json — fall back if theme editor fields are empty.
  endcomment
  assign instagram_url = section.settings.instagram_url
  assign tiktok_url    = section.settings.tiktok_url
  if instagram_url == blank
    assign instagram_url = 'https://www.instagram.com/itshoodburger?igsh=MW95ZjNjYTdtMWl3dw=='
  endif
  if tiktok_url == blank
    assign tiktok_url = 'https://www.tiktok.com/@itshoodburger?_r=1&_t=ZS-97Vo8wTqUi1'
  endif
-%}

<section class="story-about" data-section-id="{{ section.id }}">
  <div class="story-about__card">

    <div class="story-about__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1466
          | image_tag:
            class: 'story-about__img',
            loading: 'lazy',
            widths: '344, 688, 710, 1420',
            sizes: '(min-width: 750px) 33vw, 100vw',
            alt: about_alt
        }}
      {%- else -%}
        <img
          class="story-about__img"
          src="{{ about_asset | asset_url }}"
          alt="{{ about_alt | escape }}"
          width="710"
          height="461"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="story-about__body">
      {%- if section.settings.heading != blank -%}
        <h2 class="story-about__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="story-about__text rte">{{ section.settings.body }}</div>
      {%- endif -%}

      <div class="story-about__socials">
        <a href="{{ instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="{{ tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>
        </a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HB Story About",
  "tag": "section",
  "class": "hb-story-about-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Card image (overrides asset below)"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename",
      "info": "Theme asset in /assets",
      "default": "hb-story-about.jpg"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Hoodburger team at work"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>From our humble foundations as a one-night pop-up at the back of a Northbridge bar in 2015 to the restaurants you see today, Hoodburger has always had two goals to honour the golden era of fast food and to do it with the best ingredients we can get our hands on. Each store and menu builds on the last, exploring and refining different eras of fast food through design, food and experience.</p>"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL",
      "info": "Defaults to @itshoodburger (same as footer)"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "info": "Defaults to @itshoodburger (same as footer)"
    }
  ],
  "presets": [
    {
      "name": "HB Story About",
      "settings": {
        "instagram_url": "https://www.instagram.com/itshoodburger?igsh=MW95ZjNjYTdtMWl3dw==",
        "tiktok_url": "https://www.tiktok.com/@itshoodburger?_r=1&_t=ZS-97Vo8wTqUi1"
      }
    }
  ]
}
{% endschema %}
